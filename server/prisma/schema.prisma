  productId     String
  product       Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  requestedById String
  requestedBy   User              @relation("PixSellerRequester", fields: [requestedById], references: [id])
  // Seller Info
  sellerName    String
  sellerDocument String?          // CPF/CNPJ
  sellerEmail   String
  sellerPhone   String?
  // PIX Details
  pixKey        String
  pixKeyType    PixKeyType
  // Product Details (snapshot)
