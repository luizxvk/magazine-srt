generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String         @id @default(uuid())
  email                  String         @unique
  passwordHash           String
  name                   String
  displayName            String?
  avatarUrl              String?
  bio                    String?
  role                   Role           @default(MEMBER)
  points                 Int            @default(0)
  trophies               Int            @default(0)
  level                  Int            @default(1)
  xp                     Int            @default(0)
  zions                  Int            @default(0)
  membershipType         MembershipType @default(MAGAZINE)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  resetToken             String?
  resetTokenExpiry       DateTime?
  deletedAt              DateTime?
  sessionToken           String?
  isOnline               Boolean        @default(false)
  lastSeenAt             DateTime?
  equippedBackground     String?
  equippedBadge          String?
  equippedColor          String?
  liteMode               Boolean        @default(false)
  ownedCustomizations    String?
  isVerified             Boolean        @default(false)
  verificationCode       String?
  verificationExpiry     DateTime?
  verificationSentAt     DateTime?
  doNotDisturb           Boolean        @default(false)
  adminBadges            AdminBadge[]
  catalogPhotos          CatalogPhoto[]
  comments               Comment[]
  friendRequestsReceived Friendship[]   @relation("FriendRequestsReceived")
  friendRequestsSent     Friendship[]   @relation("FriendRequestsSent")
  groupsCreated          Group[]        @relation("GroupCreator")
  receivedGroupInvites   GroupInvite[]  @relation("ReceivedGroupInvites")
  sentGroupInvites       GroupInvite[]  @relation("SentGroupInvites")
  groupMemberships       GroupMember[]  @relation("UserGroupMemberships")
  groupMessages          GroupMessage[] @relation("UserGroupMessages")
  likes                  Like[]
  receivedMessages       Message[]      @relation("ReceivedMessages")
  sentMessages           Message[]      @relation("SentMessages")
  notifications          Notification[]
  pointHistory           PointHistory[]
  posts                  Post[]
  redemptions            Redemption[]
  reportsSent            Report[]       @relation("ReportsSent")
  stories                Story[]
  storyViews             StoryView[]
  badges                 UserBadge[]
  zionHistory            ZionHistory[]
  zionPurchases          ZionPurchase[]
  marketListings         MarketListing[] @relation("MarketSeller")
  marketPurchases        MarketTransaction[] @relation("MarketBuyer")
  marketSales            MarketTransaction[] @relation("MarketTransactionSeller")
  feedbacks              Feedback[]

  @@index([membershipType])
  @@index([isOnline])
  @@index([createdAt])
  @@index([trophies])
  @@index([zions])
}

model Story {
  id        String      @id @default(uuid())
  userId    String
  imageUrl  String
  createdAt DateTime    @default(now())
  expiresAt DateTime
  user      User        @relation(fields: [userId], references: [id])
  views     StoryView[]

  @@index([userId])
  @@index([expiresAt])
  @@index([createdAt])
}

model StoryView {
  id       String   @id @default(uuid())
  storyId  String
  viewerId String
  viewedAt DateTime @default(now())
  story    Story    @relation(fields: [storyId], references: [id])
  viewer   User     @relation(fields: [viewerId], references: [id])

  @@unique([storyId, viewerId])
}

model Message {
  id            String   @id @default(uuid())
  senderId      String
  receiverId    String
  content       String
  read          Boolean  @default(false)
  createdAt     DateTime @default(now())
  storyImageUrl String?
  receiver      User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender        User     @relation("SentMessages", fields: [senderId], references: [id])

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
  @@index([senderId, receiverId])
}

model Post {
  id            String    @id @default(uuid())
  userId        String
  imageUrl      String?
  videoUrl      String?
  caption       String?
  likesCount    Int       @default(0)
  commentsCount Int       @default(0)
  isHighlight   Boolean   @default(false)
  mediaType     MediaType @default(IMAGE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  isPublic      Boolean   @default(true)
  isRemoved     Boolean   @default(false)
  reportsCount  Int       @default(0)
  comments      Comment[]
  likes         Like[]
  user          User      @relation(fields: [userId], references: [id])
  tags          PostTag[]

  @@index([userId])
  @@index([createdAt])
  @@index([isHighlight])
  @@index([isRemoved])
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  text      String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([postId])
  @@index([userId])
  @@index([createdAt])
}

model Like {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
}

model Badge {
  id          String      @id @default(uuid())
  name        String
  description String
  iconUrl     String
  trophies    Int         @default(0)
  users       UserBadge[]
}

model UserBadge {
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())
  badge     Badge    @relation(fields: [badgeId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@id([userId, badgeId])
}

model Reward {
  id              String       @id @default(uuid())
  title           String
  type            RewardType
  costZions       Int          @default(0)
  zionsReward     Int?         @default(0)
  stock           Int
  isUnlimited     Boolean      @default(true)
  metadata        Json?
  backgroundColor String?
  redemptions     Redemption[]
}

model Redemption {
  id          String    @id @default(uuid())
  userId      String
  rewardId    String
  cost        Int
  redeemedAt  DateTime  @default(now())
  completedAt DateTime?
  metadata    Json?
  status      String    @default("PENDING")
  reward      Reward    @relation(fields: [rewardId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
}

model PointHistory {
  id        String   @id @default(uuid())
  userId    String
  amount    Int
  reason    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model ZionHistory {
  id        String   @id @default(uuid())
  userId    String
  amount    Int
  reason    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Friendship {
  id          String           @id @default(uuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  addressee   User             @relation("FriendRequestsReceived", fields: [addresseeId], references: [id])
  requester   User             @relation("FriendRequestsSent", fields: [requesterId], references: [id])

  @@unique([requesterId, addresseeId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  content   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@index([userId, read])
}

model PostTag {
  id     String @id @default(uuid())
  postId String
  tag    String
  post   Post   @relation(fields: [postId], references: [id])
}

model InviteRequest {
  id        String        @id @default(uuid())
  name      String
  email     String        @unique
  instagram String?
  status    RequestStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Announcement {
  id                 String   @id @default(uuid())
  title              String
  logoUrl            String
  tag                String
  subscriptionType   String
  description        String
  backgroundImageUrl String?
  buttonText         String   @default("Conhecer Agora")
  link               String   @default("/srt-log")
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model PageContent {
  id        String   @id @default(uuid())
  key       String   @unique
  content   Json
  updatedAt DateTime @updatedAt
}

model SystemLog {
  id        String   @id @default(uuid())
  level     String
  source    String
  message   String
  timestamp DateTime @default(now())
  metadata  Json?
}

model CatalogPhoto {
  id          String   @id @default(uuid())
  userId      String
  imageUrl    String
  title       String?
  description String?
  category    String?
  carValue    String?
  eventType   String?
  carBrand    String?
  isPublic    Boolean  @default(true)
  isFavorite  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}

model ZionPurchase {
  id           String   @id @default(uuid())
  userId       String
  amount       Int
  price        Float
  paymentId    String?
  preferenceId String?
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime
  imageUrl    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  category    String?
  game        String?
}

model Report {
  id         String       @id @default(uuid())
  reporterId String
  postId     String?
  userId     String?
  reason     String
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  resolvedAt DateTime?
  resolvedBy String?
  reporter   User         @relation("ReportsSent", fields: [reporterId], references: [id])
}

model Group {
  id             String         @id @default(uuid())
  name           String
  description    String?
  avatarUrl      String?
  creatorId      String
  membershipType MembershipType
  isPrivate      Boolean        @default(false)
  maxMembers     Int            @default(100)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  backgroundId   String?
  nsfw           Boolean        @default(false)
  creator        User           @relation("GroupCreator", fields: [creatorId], references: [id])
  invites        GroupInvite[]
  members        GroupMember[]
  messages       GroupMessage[]
  settings       GroupSettings?

  @@index([creatorId])
  @@index([membershipType])
  @@index([isPrivate])
  @@index([createdAt])
}

model GroupMember {
  id          String    @id @default(uuid())
  groupId     String
  userId      String
  role        GroupRole @default(MEMBER)
  joinedAt    DateTime  @default(now())
  canPost     Boolean   @default(true)
  canInvite   Boolean   @default(false)
  canModerate Boolean   @default(false)
  isMuted     Boolean   @default(false)
  nickname    String?
  group       Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user        User      @relation("UserGroupMemberships", fields: [userId], references: [id])

  @@unique([groupId, userId])
  @@index([userId])
  @@index([role])
}

model GroupMessage {
  id        String      @id @default(uuid())
  groupId   String
  senderId  String
  content   String
  imageUrl  String?
  type      MessageType @default(TEXT)
  createdAt DateTime    @default(now())
  editedAt  DateTime?
  deletedAt DateTime?
  isNSFW    Boolean     @default(false)
  group     Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender    User        @relation("UserGroupMessages", fields: [senderId], references: [id])

  @@index([groupId])
  @@index([senderId])
  @@index([createdAt])
}

model GroupSettings {
  id                   String  @id @default(uuid())
  groupId              String  @unique
  requireApproval      Boolean @default(false)
  allowMemberPosts     Boolean @default(true)
  allowExternalInvites Boolean @default(false)
  muteNotifications    Boolean @default(false)
  group                Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model GroupInvite {
  id          String       @id @default(uuid())
  groupId     String
  inviterId   String
  invitedId   String
  status      InviteStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  respondedAt DateTime?
  group       Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  invited     User         @relation("ReceivedGroupInvites", fields: [invitedId], references: [id])
  inviter     User         @relation("SentGroupInvites", fields: [inviterId], references: [id])

  @@unique([groupId, invitedId])
  @@index([invitedId])
  @@index([inviterId])
  @@index([status])
}

model AdminBadge {
  id        String   @id @default(uuid())
  text      String
  color     String
  userId    String
  createdAt DateTime @default(now())
  createdBy String
  textColor String   @default("#FFFFFF")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdBy])
}

// ========== MARKET SYSTEM ==========

model MarketListing {
  id           String              @id @default(uuid())
  sellerId     String
  itemId       String              // The customization item ID (bg_aurora, badge_skull, etc.)
  itemType     String              // 'background' | 'badge' | 'color'
  price        Int                 // Price in Zions
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  status       MarketListingStatus @default(ACTIVE)
  seller       User                @relation("MarketSeller", fields: [sellerId], references: [id])
  transactions MarketTransaction[]

  @@index([sellerId])
  @@index([itemType])
  @@index([status])
  @@index([price])
  @@index([createdAt])
}

model MarketTransaction {
  id          String        @id @default(uuid())
  listingId   String
  buyerId     String
  sellerId    String
  itemId      String
  itemType    String
  price       Int
  createdAt   DateTime      @default(now())
  listing     MarketListing @relation(fields: [listingId], references: [id])
  buyer       User          @relation("MarketBuyer", fields: [buyerId], references: [id])
  seller      User          @relation("MarketTransactionSeller", fields: [sellerId], references: [id])

  @@index([buyerId])
  @@index([sellerId])
  @@index([createdAt])
}

enum MarketListingStatus {
  ACTIVE
  SOLD
  CANCELLED
}

model Feedback {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  
  // Ratings (1-5)
  interfaceRating   Int      // Interface geral
  navigationRating  Int      // Facilidade de navegação
  performanceRating Int      // Velocidade/Performance
  designRating      Int      // Design visual
  featuresRating    Int      // Funcionalidades
  
  // Text answers
  bugsFound         String?  @db.Text // Bugs encontrados
  favoriteFeature   String?  // Funcionalidade favorita
  missingFeature    String?  @db.Text // O que está faltando
  wouldRecommend    Boolean  // Recomendaria?
  overallExperience String?  @db.Text // Experiência geral
  suggestions       String?  @db.Text // Sugestões de melhoria
  
  // Additional ratings
  communityRating   Int      // Comunidade/Social
  customizationRating Int    // Sistema de customização
  supportRating     Int      // Suporte/Ajuda
  
  isRead            Boolean  @default(false)
  createdAt         DateTime @default(now())
  
  @@index([userId])
  @@index([createdAt])
  @@index([isRead])
}

enum Role {
  MEMBER
  ADMIN
  VISITOR
}

enum MembershipType {
  MAGAZINE
  MGT
}

enum RewardType {
  PRODUCT
  COUPON
  DIGITAL
}

enum NotificationType {
  LIKE
  COMMENT
  SYSTEM
  BADGE
  FRIEND_REQUEST
  MESSAGE
  GROUP_INVITE
}

enum MediaType {
  IMAGE
  VIDEO
  TEXT
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

enum GroupRole {
  ADMIN
  MODERATOR
  MEMBER
}

enum MessageType {
  TEXT
  IMAGE
  ANNOUNCEMENT
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}
