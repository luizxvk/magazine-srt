  productDescription String       @db.Text
  // Request
  justification String?           @db.Text
  status        PixApprovalStatus @default(PENDING)
  reviewedAt    DateTime?
  reviewNote    String?           @db.Text
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([productId])
  @@index([status])
  @@index([requestedById])
