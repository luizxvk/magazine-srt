generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String         @id @default(uuid())
  email                  String         @unique
  passwordHash           String
  name                   String
  displayName            String?
  avatarUrl              String?
  bio                    String?
  role                   Role           @default(MEMBER)
  points                 Int            @default(0)
  trophies               Int            @default(0)
  level                  Int            @default(1)
  xp                     Int            @default(0)
  zions                  Int            @default(0) // DEPRECATED - usar zionsPoints e zionsCash
  zionsPoints            Int            @default(0) // Moeda para customizações (100 points = 1 cash)
  zionsCash              Float          @default(0) // Moeda real (1 cash = R$ 1,00)
  membershipType         MembershipType @default(MAGAZINE)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  resetToken             String?
  resetTokenExpiry       DateTime?
  deletedAt              DateTime?
  sessionToken           String?
  isOnline               Boolean        @default(false)
  lastSeenAt             DateTime?
  equippedBackground     String?
  equippedBadge          String?
  equippedColor          String?
  liteMode               Boolean        @default(false)
  ownedCustomizations    String?
  isVerified             Boolean        @default(false)
  verificationCode       String?
  verificationExpiry     DateTime?
  verificationSentAt     DateTime?
  doNotDisturb           Boolean        @default(false)
  // Profile card background settings
  profileBgUrl           String?        // URL da imagem de fundo do card de perfil
  profileBgScale         Float?         @default(1) // Escala do background (1 = 100%)
  profileBgPosX          Float?         @default(50) // Posição X em porcentagem
  profileBgPosY          Float?         @default(50) // Posição Y em porcentagem
  adminBadges            AdminBadge[]
  catalogPhotos          CatalogPhoto[]
  comments               Comment[]
  friendRequestsReceived Friendship[]   @relation("FriendRequestsReceived")
  friendRequestsSent     Friendship[]   @relation("FriendRequestsSent")
  groupsCreated          Group[]        @relation("GroupCreator")
  receivedGroupInvites   GroupInvite[]  @relation("ReceivedGroupInvites")
  sentGroupInvites       GroupInvite[]  @relation("SentGroupInvites")
  groupMemberships       GroupMember[]  @relation("UserGroupMemberships")
  groupMessages          GroupMessage[] @relation("UserGroupMessages")
  groupMessageReactions  GroupMessageReaction[] @relation("UserGroupMessageReactions")
  likes                  Like[]
  receivedMessages       Message[]      @relation("ReceivedMessages")
  sentMessages           Message[]      @relation("SentMessages")
  notifications          Notification[]
  pointHistory           PointHistory[]
  posts                  Post[]
  redemptions            Redemption[]
  reportsSent            Report[]       @relation("ReportsSent")
  stories                Story[]
  storyViews             StoryView[]
  badges                 UserBadge[]
  zionHistory            ZionHistory[]
  zionPurchases          ZionPurchase[]
  marketListings         MarketListing[] @relation("MarketSeller")
  marketPurchases        MarketTransaction[] @relation("MarketBuyer")
  marketSales            MarketTransaction[] @relation("MarketTransactionSeller")
  feedbacks              Feedback[]
  withdrawalRequests     WithdrawalRequest[]
  createdProducts        Product[]  @relation("ProductCreator")
  themePacks             UserThemePack[]
  socialConnections      SocialConnection[]
  socialActivities       SocialActivity[]
  pushSubscriptions      PushSubscription[]

  @@index([membershipType])
  @@index([isOnline])
  @@index([createdAt])
  @@index([trophies])
  @@index([zions])
}

model Story {
  id        String      @id @default(uuid())
  userId    String
  imageUrl  String
  createdAt DateTime    @default(now())
  expiresAt DateTime
  user      User        @relation(fields: [userId], references: [id])
  views     StoryView[]

  @@index([userId])
  @@index([expiresAt])
  @@index([createdAt])
}

model StoryView {
  id       String   @id @default(uuid())
  storyId  String
  viewerId String
  viewedAt DateTime @default(now())
  story    Story    @relation(fields: [storyId], references: [id])
  viewer   User     @relation(fields: [viewerId], references: [id])

  @@unique([storyId, viewerId])
}

model Message {
  id            String   @id @default(uuid())
  senderId      String
  receiverId    String
  content       String
  read          Boolean  @default(false)
  createdAt     DateTime @default(now())
  storyImageUrl String?
  receiver      User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender        User     @relation("SentMessages", fields: [senderId], references: [id])

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
  @@index([senderId, receiverId])
}

model Post {
  id              String    @id @default(uuid())
  userId          String
  imageUrl        String?
  videoUrl        String?
  caption         String?
  likesCount      Int       @default(0)
  commentsCount   Int       @default(0)
  isHighlight     Boolean   @default(false)
  mediaType       MediaType @default(IMAGE)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  isPublic        Boolean   @default(true)
  isRemoved       Boolean   @default(false)
  reportsCount    Int       @default(0)
  linkedProductId String?   // ID do produto vinculado (para destaques de loja)
  linkedProduct   Product?  @relation("PostProduct", fields: [linkedProductId], references: [id])
  comments        Comment[]
  likes           Like[]
  user            User      @relation(fields: [userId], references: [id])
  tags            PostTag[]

  @@index([userId])
  @@index([createdAt])
  @@index([isHighlight])
  @@index([isRemoved])
  @@index([linkedProductId])
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  text      String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([postId])
  @@index([userId])
  @@index([createdAt])
}

model Like {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
}

model Badge {
  id          String      @id @default(uuid())
  name        String      @unique
  description String
  iconUrl     String
  trophies    Int         @default(0)
  users       UserBadge[]
}

model UserBadge {
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())
  badge     Badge    @relation(fields: [badgeId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@id([userId, badgeId])
}

model Reward {
  id              String       @id @default(uuid())
  title           String
  type            RewardType
  costZions       Int          @default(0)
  zionsReward     Int?         @default(0)
  stock           Int
  isUnlimited     Boolean      @default(true)
  metadata        Json?
  backgroundColor String?
  redemptions     Redemption[]
}

model Redemption {
  id          String    @id @default(uuid())
  userId      String
  rewardId    String
  cost        Int
  redeemedAt  DateTime  @default(now())
  completedAt DateTime?
  metadata    Json?
  status      String    @default("PENDING")
  reward      Reward    @relation(fields: [rewardId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
}

model PointHistory {
  id        String   @id @default(uuid())
  userId    String
  amount    Int
  reason    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model ZionHistory {
  id        String   @id @default(uuid())
  userId    String
  amount    Int
  reason    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Friendship {
  id          String           @id @default(uuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  addressee   User             @relation("FriendRequestsReceived", fields: [addresseeId], references: [id])
  requester   User             @relation("FriendRequestsSent", fields: [requesterId], references: [id])

  @@unique([requesterId, addresseeId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  content   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@index([userId, read])
}

model PostTag {
  id     String @id @default(uuid())
  postId String
  tag    String
  post   Post   @relation(fields: [postId], references: [id])
}

model InviteRequest {
  id        String        @id @default(uuid())
  name      String
  email     String        @unique
  instagram String?
  status    RequestStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Announcement {
  id                 String   @id @default(uuid())
  title              String
  logoUrl            String
  tag                String
  subscriptionType   String
  description        String
  backgroundImageUrl String?
  buttonText         String   @default("Conhecer Agora")
  link               String   @default("/srt-log")
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model PageContent {
  id        String   @id @default(uuid())
  key       String   @unique
  content   Json
  updatedAt DateTime @updatedAt
}

model SystemLog {
  id        String   @id @default(uuid())
  level     String
  source    String
  message   String
  timestamp DateTime @default(now())
  metadata  Json?
}

model CatalogPhoto {
  id          String   @id @default(uuid())
  userId      String
  imageUrl    String
  title       String?
  description String?
  category    String?
  carValue    String?
  eventType   String?
  carBrand    String?
  isPublic    Boolean  @default(true)
  isFavorite  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}

model ZionPurchase {
  id              String   @id @default(uuid())
  userId          String
  amount          Int      // Quantidade de Zions
  price           Float    // Preço em reais
  paymentId       String?  @unique // ID do pagamento no Mercado Pago
  preferenceId    String?  @unique // ID da preferência no Mercado Pago
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED, CANCELLED, REFUNDED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([paymentId])
  @@index([preferenceId])
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime
  imageUrl    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  category    String?
  game        String?
}

model Report {
  id         String       @id @default(uuid())
  reporterId String
  postId     String?
  userId     String?
  reason     String
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  resolvedAt DateTime?
  resolvedBy String?
  reporter   User         @relation("ReportsSent", fields: [reporterId], references: [id])
}

model Group {
  id             String         @id @default(uuid())
  name           String
  description    String?
  avatarUrl      String?
  creatorId      String
  membershipType MembershipType
  isPrivate      Boolean        @default(false)
  maxMembers     Int            @default(100)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  backgroundId   String?
  nsfw           Boolean        @default(false)
  creator        User           @relation("GroupCreator", fields: [creatorId], references: [id])
  invites        GroupInvite[]
  members        GroupMember[]
  messages       GroupMessage[]
  settings       GroupSettings?

  @@index([creatorId])
  @@index([membershipType])
  @@index([isPrivate])
  @@index([createdAt])
}

model GroupMember {
  id          String    @id @default(uuid())
  groupId     String
  userId      String
  role        GroupRole @default(MEMBER)
  joinedAt    DateTime  @default(now())
  canPost     Boolean   @default(true)
  canInvite   Boolean   @default(false)
  canModerate Boolean   @default(false)
  isMuted     Boolean   @default(false)
  nickname    String?
  group       Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user        User      @relation("UserGroupMemberships", fields: [userId], references: [id])

  @@unique([groupId, userId])
  @@index([userId])
  @@index([role])
}

model GroupMessage {
  id        String      @id @default(uuid())
  groupId   String
  senderId  String
  content   String
  imageUrl  String?
  type      MessageType @default(TEXT)
  createdAt DateTime    @default(now())
  editedAt  DateTime?
  deletedAt DateTime?
  isNSFW    Boolean     @default(false)
  replyToId String?
  group     Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender    User        @relation("UserGroupMessages", fields: [senderId], references: [id])
  readBy    GroupMessageRead[]
  reactions GroupMessageReaction[]
  replyTo   GroupMessage?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   GroupMessage[] @relation("MessageReplies")

  @@index([groupId])
  @@index([senderId])
  @@index([createdAt])
  @@index([replyToId])
}

model GroupMessageReaction {
  id        String       @id @default(uuid())
  messageId String
  userId    String
  emoji     String       // e.g., "👍", "❤️", "😂"
  createdAt DateTime     @default(now())
  message   GroupMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User         @relation("UserGroupMessageReactions", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@index([userId])
}

// Track which users have read which messages
model GroupMessageRead {
  id        String       @id @default(uuid())
  messageId String
  userId    String
  readAt    DateTime     @default(now())
  message   GroupMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
}

model GroupSettings {
  id                   String  @id @default(uuid())
  groupId              String  @unique
  requireApproval      Boolean @default(false)
  allowMemberPosts     Boolean @default(true)
  allowExternalInvites Boolean @default(false)
  muteNotifications    Boolean @default(false)
  group                Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model GroupInvite {
  id          String       @id @default(uuid())
  groupId     String
  inviterId   String
  invitedId   String
  status      InviteStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  respondedAt DateTime?
  group       Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  invited     User         @relation("ReceivedGroupInvites", fields: [invitedId], references: [id])
  inviter     User         @relation("SentGroupInvites", fields: [inviterId], references: [id])

  @@unique([groupId, invitedId])
  @@index([invitedId])
  @@index([inviterId])
  @@index([status])
}

model AdminBadge {
  id        String   @id @default(uuid())
  text      String
  color     String
  userId    String
  createdAt DateTime @default(now())
  createdBy String
  textColor String   @default("#FFFFFF")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdBy])
}

// ========== MARKET SYSTEM ==========

model MarketListing {
  id           String              @id @default(uuid())
  sellerId     String
  itemId       String              // The customization item ID (bg_aurora, badge_skull, etc.)
  itemType     String              // 'background' | 'badge' | 'color'
  price        Int                 // Price in Zions
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  status       MarketListingStatus @default(ACTIVE)
  seller       User                @relation("MarketSeller", fields: [sellerId], references: [id])
  transactions MarketTransaction[]

  @@index([sellerId])
  @@index([itemType])
  @@index([status])
  @@index([price])
  @@index([createdAt])
}

model MarketTransaction {
  id          String        @id @default(uuid())
  listingId   String
  buyerId     String
  sellerId    String
  itemId      String
  itemType    String
  price       Int
  createdAt   DateTime      @default(now())
  listing     MarketListing @relation(fields: [listingId], references: [id])
  buyer       User          @relation("MarketBuyer", fields: [buyerId], references: [id])
  seller      User          @relation("MarketTransactionSeller", fields: [sellerId], references: [id])

  @@index([buyerId])
  @@index([sellerId])
  @@index([createdAt])
}

enum MarketListingStatus {
  ACTIVE
  SOLD
  CANCELLED
}

// ========== PRODUCT STORE SYSTEM ==========

model Product {
  id            String          @id @default(uuid())
  name          String
  description   String          @db.Text
  imageUrl      String?
  screenshots   String[]        // Array of additional screenshot URLs
  category      ProductCategory
  priceZions    Int?            // Price in Zions (optional)
  priceBRL      Float?          // Price in BRL (optional)
  stock         Int             @default(0)
  isUnlimited   Boolean         @default(false)
  isActive      Boolean         @default(true)
  magazineDiscount Boolean      @default(false) // 10% discount for MAGAZINE members
  // Game/Product Info
  developer     String?         // Developer/Publisher
  releaseDate   String?         // Release date
  sizeGB        Float?          // Size in GB
  platform      String?         // Platform (PC, Xbox, PS, etc)
  tags          ProductTag[]    // Tags relationship
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  createdById   String
  createdBy     User            @relation("ProductCreator", fields: [createdById], references: [id])
  keys          ProductKey[]
  orders        Order[]
  linkedPosts   Post[]          @relation("PostProduct")
  
  @@index([category])
  @@index([isActive])
  @@index([priceZions])
  @@index([priceBRL])
}

model ProductTag {
  id        String   @id @default(uuid())
  productId String
  tag       String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@unique([productId, tag])
  @@index([tag])
}

model ProductKey {
  id          String    @id @default(uuid())
  productId   String
  key         String    // The actual game key/code (encrypted in production)
  isUsed      Boolean   @default(false)
  usedAt      DateTime?
  usedById    String?
  orderId     String?
  createdAt   DateTime  @default(now())
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  order       Order?    @relation(fields: [orderId], references: [id])
  
  @@index([productId])
  @@index([isUsed])
}

model Order {
  id            String        @id @default(uuid())
  buyerId       String
  productId     String
  quantity      Int           @default(1)
  totalZions    Int?          // Total paid in Zions
  totalBRL      Float?        // Total paid in BRL
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(PENDING)
  paymentId     String?       // External payment ID (Stripe/MercadoPago)
  deliveredKeys ProductKey[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  product       Product       @relation(fields: [productId], references: [id])
  
  @@index([buyerId])
  @@index([productId])
  @@index([paymentStatus])
  @@index([createdAt])
}

// ========== WITHDRAWAL SYSTEM ==========

model WithdrawalRequest {
  id            String           @id @default(uuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id])
  amountZions   Int              // Zions to convert
  amountBRL     Float            // BRL to receive
  pixKey        String           // PIX key for payment
  pixKeyType    PixKeyType
  status        WithdrawalStatus @default(PENDING)
  processedAt   DateTime?
  processedById String?
  rejectionNote String?
  createdAt     DateTime         @default(now())
  
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

enum ProductCategory {
  GAME_KEY
  GIFT_CARD
  SUBSCRIPTION
  DIGITAL_ITEM
  SERVICE
}

enum PaymentMethod {
  ZIONS
  PIX
  CREDIT_CARD
  MERCADO_PAGO
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum PixKeyType {
  CPF
  CNPJ
  EMAIL
  PHONE
  RANDOM
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
}

model Feedback {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  
  // Ratings (1-5)
  interfaceRating   Int      // Interface geral
  navigationRating  Int      // Facilidade de navegação
  performanceRating Int      // Velocidade/Performance
  designRating      Int      // Design visual
  featuresRating    Int      // Funcionalidades
  
  // Text answers
  bugsFound         String?  @db.Text // Bugs encontrados
  favoriteFeature   String?  // Funcionalidade favorita
  missingFeature    String?  @db.Text // O que está faltando
  wouldRecommend    Boolean  // Recomendaria?
  overallExperience String?  @db.Text // Experiência geral
  suggestions       String?  @db.Text // Sugestões de melhoria
  
  // Additional ratings
  communityRating   Int      // Comunidade/Social
  customizationRating Int    // Sistema de customização
  supportRating     Int      // Suporte/Ajuda
  
  isRead            Boolean  @default(false)
  createdAt         DateTime @default(now())
  
  @@index([userId])
  @@index([createdAt])
  @@index([isRead])
}

enum Role {
  MEMBER
  ADMIN
  VISITOR
}

enum MembershipType {
  MAGAZINE
  MGT
}

enum RewardType {
  PRODUCT
  COUPON
  DIGITAL
}

enum NotificationType {
  LIKE
  COMMENT
  SYSTEM
  BADGE
  FRIEND_REQUEST
  MESSAGE
  GROUP_INVITE
  GROUP_MENTION
}

enum MediaType {
  IMAGE
  VIDEO
  TEXT
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

enum GroupRole {
  ADMIN
  MODERATOR
  MEMBER
}

enum MessageType {
  TEXT
  IMAGE
  ANNOUNCEMENT
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum ThemePackRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

model ThemePack {
  id              String          @id @default(uuid())
  name            String          // "Arc Raiders Pack"
  description     String?
  gameTitle       String          // "Arc Raiders"
  backgroundUrl   String          // URL do fundo animado (video/gif/webm)
  accentColor     String          // Hex da cor destaque "#FF6B35"
  previewUrl      String?         // Thumbnail estática para preview
  price           Int             // Preço em Zions
  fontFamily      String?         // Fonte customizada para título
  maxStock        Int?            // Estoque máximo (null = ilimitado)
  soldCount       Int             @default(0)
  isActive        Boolean         @default(true)
  isLimited       Boolean         @default(false) // Edição limitada?
  rarity          ThemePackRarity @default(COMMON) // Raridade do pack
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  owners          UserThemePack[]

  @@index([isActive])
  @@index([gameTitle])
  @@index([rarity])
}

model UserThemePack {
  id          String    @id @default(uuid())
  userId      String
  packId      String
  purchasedAt DateTime  @default(now())
  isEquipped  Boolean   @default(false)
  price       Int       // Preço pago (para histórico)
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  pack        ThemePack @relation(fields: [packId], references: [id], onDelete: Cascade)
  
  @@unique([userId, packId])
  @@index([userId])
  @@index([packId])
  @@index([isEquipped])
}

enum SocialPlatform {
  DISCORD
  STEAM
  TWITCH
}

model SocialConnection {
  id            String         @id @default(uuid())
  userId        String
  platform      SocialPlatform
  platformId    String         // ID do usuário na plataforma (Discord ID, Steam ID, Twitch ID)
  platformUsername String?     // Username na plataforma
  accessToken   String?        // OAuth access token (encriptado)
  refreshToken  String?        // OAuth refresh token (encriptado)
  expiresAt     DateTime?      // Quando o token expira
  isActive      Boolean        @default(true)
  lastSynced    DateTime?      // Última vez que sincronizou dados
  metadata      Json?          // Dados extras (avatar, status, etc)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, platform])
  @@index([userId])
  @@index([platform])
  @@index([platformId])
}

model SocialActivity {
  id            String         @id @default(uuid())
  userId        String
  platform      SocialPlatform
  activityType  String         // "playing", "streaming", "online", "offline"
  gameName      String?        // Nome do jogo sendo jogado
  gameId        String?        // ID do jogo (Steam App ID, etc)
  status        String?        // Status customizado
  startedAt     DateTime       @default(now())
  endedAt       DateTime?
  isLive        Boolean        @default(false) // Se está em livestream
  streamUrl     String?        // URL da livestream
  thumbnailUrl  String?        // Thumbnail da atividade
  metadata      Json?          // Dados extras
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([platform])
  @@index([activityType])
  @@index([isLive])
  @@index([startedAt])
}

// ============================================
// PUSH NOTIFICATIONS
// ============================================

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  keys      Json     // { p256dh: string, auth: string }
  userAgent String?  // Browser/device info
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

// ============================================
// SYSTEM CONFIGURATION
// ============================================

model SystemConfig {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}
