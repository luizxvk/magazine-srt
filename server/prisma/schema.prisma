generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String         @id @default(uuid())
  email                  String         @unique
  passwordHash           String
  name                   String
  displayName            String?
  avatarUrl              String?
  bio                    String?
  role                   Role           @default(MEMBER)
  points                 Int            @default(0)
  trophies               Int            @default(0)
  level                  Int            @default(1)
  xp                     Int            @default(0)
  zions                  Int            @default(0) // DEPRECATED - usar zionsPoints e zionsCash
  zionsPoints            Int            @default(0) // Moeda para customizações (100 points = 1 cash)
  zionsCash              Float          @default(0) // Moeda real (1 cash = R$ 1,00)
  membershipType         MembershipType @default(MAGAZINE)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  resetToken             String?
  resetTokenExpiry       DateTime?
  deletedAt              DateTime?
  sessionToken           String?
  isOnline               Boolean        @default(false)
  lastSeenAt             DateTime?
  equippedBackground     String?
  equippedBadge          String?
  equippedColor          String?
  equippedProfileBorder  String?
  liteMode               Boolean        @default(false)
  ownedCustomizations    String?
  isVerified             Boolean        @default(false)
  verificationCode       String?
  verificationExpiry     DateTime?
  verificationSentAt     DateTime?
  doNotDisturb           Boolean        @default(false)
  showWelcomeCard        Boolean        @default(true) // Toggle para mostrar/esconder card de boas-vindas no feed
  // Profile card background settings
  profileBgUrl           String?        // URL da imagem de fundo do card de perfil
  profileBgScale         Float?         @default(1) // Escala do background (1 = 100%)
  profileBgPosX          Float?         @default(50) // Posição X em porcentagem
  profileBgPosY          Float?         @default(50) // Posição Y em porcentagem
  adminBadges            AdminBadge[]
  catalogPhotos          CatalogPhoto[]
  comments               Comment[]
  friendRequestsReceived Friendship[]   @relation("FriendRequestsReceived")
  friendRequestsSent     Friendship[]   @relation("FriendRequestsSent")
  groupsCreated          Group[]        @relation("GroupCreator")
  receivedGroupInvites   GroupInvite[]  @relation("ReceivedGroupInvites")
  sentGroupInvites       GroupInvite[]  @relation("SentGroupInvites")
  groupMemberships       GroupMember[]  @relation("UserGroupMemberships")
  groupMessages          GroupMessage[] @relation("UserGroupMessages")
  groupMessageReactions  GroupMessageReaction[] @relation("UserGroupMessageReactions")
  likes                  Like[]
  receivedMessages       Message[]      @relation("ReceivedMessages")
  sentMessages           Message[]      @relation("SentMessages")
  notifications          Notification[]
  pointHistory           PointHistory[]
  posts                  Post[]
  redemptions            Redemption[]
  reportsSent            Report[]       @relation("ReportsSent")
  stories                Story[]
  storyViews             StoryView[]
  badges                 UserBadge[]
  zionHistory            ZionHistory[]
  zionPurchases          ZionPurchase[]
  marketListings         MarketListing[] @relation("MarketSeller")
  marketPurchases        MarketTransaction[] @relation("MarketBuyer")
  marketSales            MarketTransaction[] @relation("MarketTransactionSeller")
  feedbacks              Feedback[]
  withdrawalRequests     WithdrawalRequest[]
  createdProducts        Product[]  @relation("ProductCreator")
  pixSellerRequests      PixSellerRequest[] @relation("PixSellerRequester")
  themePacks             UserThemePack[]
  socialConnections      SocialConnection[]
  socialActivities       SocialActivity[]
  pushSubscriptions      PushSubscription[]
  pollVotes              PollVote[]
  betaRewardClaimed      Boolean        @default(false) // Track if user claimed v0.5.0 beta reward
  eventDropClaims        EventDropClaim[]
  // Elite Subscription
  isElite                Boolean        @default(false)
  eliteUntil             DateTime?      // Quando a assinatura expira
  eliteSince             DateTime?      // Quando se tornou Elite
  eliteStreak            Int            @default(0) // Meses consecutivos como Elite
  streakProtectedUntil   DateTime?      // Proteção de streak do login diário
  subscriptions          Subscription[]
  orders                 Order[]
  // Market 6.0
  isTrustedSeller        Boolean        @default(false) // Badge de vendedor confiável
  marketSalesCount       Int            @default(0) // Total de vendas no mercado
  marketFavorites        MarketFavorite[]  // Itens salvos/favoritos
  marketOffersSent       MarketOffer[]  @relation("OfferBuyer")
  marketOffersReceived   MarketOffer[]  @relation("OfferSeller")
  commentLikes           CommentLike[]
  eventAttendance        EventAttendee[]
  // StatForge - Game Tracker
  gameProfiles           GameProfile[]
  // Challenge System - 1v1 Duels
  challengesSent         Challenge[]    @relation("ChallengeSent")
  challengesReceived     Challenge[]    @relation("ChallengeReceived")
  // Prestige System
  prestigeLevel          Int            @default(0)  // Current prestige tier (0-10)
  prestigeStars          Int            @default(0)  // Visual stars count
  lastPrestigedAt        DateTime?                   // When last prestiged
  // Feed Cards Customization
  feedCardsConfig        Json?          // { cards: [{id: 'tools', visible: true, order: 0}, ...] }
  // Sponsored Posts
  sponsoredPostRequests  SponsoredPostRequest[] @relation("SponsoredPostRequests")
  sponsoredPostsReviewed SponsoredPostRequest[] @relation("SponsoredPostReviewer")
  // Rovex Connect - Voice
  voiceParticipants      VoiceParticipant[]

  @@index([membershipType])
  @@index([isElite])
  @@index([isOnline])
  @@index([createdAt])
  @@index([trophies])
  @@index([zions])
  @@index([isTrustedSeller])
}

model Story {
  id        String      @id @default(uuid())
  userId    String
  imageUrl  String
  createdAt DateTime    @default(now())
  expiresAt DateTime
  user      User        @relation(fields: [userId], references: [id])
  views     StoryView[]

  @@index([userId])
  @@index([expiresAt])
  @@index([createdAt])
}

model StoryView {
  id       String   @id @default(uuid())
  storyId  String
  viewerId String
  viewedAt DateTime @default(now())
  story    Story    @relation(fields: [storyId], references: [id])
  viewer   User     @relation(fields: [viewerId], references: [id])

  @@unique([storyId, viewerId])
}

model Message {
  id            String   @id @default(uuid())
  senderId      String
  receiverId    String
  content       String
  read          Boolean  @default(false)
  createdAt     DateTime @default(now())
  storyImageUrl String?
  receiver      User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender        User     @relation("SentMessages", fields: [senderId], references: [id])

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
  @@index([senderId, receiverId])
}

model Post {
  id              String       @id @default(uuid())
  userId          String
  imageUrl        String?
  videoUrl        String?
  caption         String?
  likesCount      Int          @default(0)
  commentsCount   Int          @default(0)
  isHighlight     Boolean      @default(false)
  mediaType       MediaType    @default(IMAGE)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  isPublic        Boolean      @default(true)
  isRemoved       Boolean      @default(false)
  reportsCount    Int          @default(0)
  linkedProductId String?      // ID do produto vinculado (para destaques de loja)
  // Poll fields
  pollQuestion    String?      // Pergunta da enquete (opcional, usa caption se vazio)
  pollOptions     PollOption[] // Opções da enquete
  linkedProduct   Product?     @relation("PostProduct", fields: [linkedProductId], references: [id])
  comments        Comment[]
  likes           Like[]
  user            User         @relation(fields: [userId], references: [id])
  tags            PostTag[]
  sponsoredRequests SponsoredPostRequest[]

  @@index([userId])
  @@index([createdAt])
  @@index([isHighlight])
  @@index([isRemoved])
  @@index([linkedProductId])
}

// Enquete - Opção de votação
model PollOption {
  id        String     @id @default(uuid())
  postId    String
  text      String
  votes     PollVote[]
  post      Post       @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

// Enquete - Voto do usuário
model PollVote {
  id        String     @id @default(uuid())
  optionId  String
  userId    String
  createdAt DateTime   @default(now())
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([optionId, userId]) // Um voto por usuário por opção
  @@index([optionId])
  @@index([userId])
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  text      String
  createdAt DateTime @default(now())
  
  // Reply threading
  parentId  String?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  
  // Relations
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  likes     CommentLike[]

  @@index([postId])
  @@index([userId])
  @@index([parentId])
  @@index([createdAt])
}

model CommentLike {
  id        String   @id @default(uuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
}

model Like {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
}

model Badge {
  id          String      @id @default(uuid())
  name        String      @unique
  description String
  iconUrl     String
  trophies    Int         @default(0)
  users       UserBadge[]
}

model UserBadge {
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())
  badge     Badge    @relation(fields: [badgeId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@id([userId, badgeId])
}

model Reward {
  id              String       @id @default(uuid())
  title           String
  type            RewardType
  costZions       Int          @default(0)
  zionsReward     Int?         @default(0)
  stock           Int
  isUnlimited     Boolean      @default(true)
  metadata        Json?
  backgroundColor String?
  redemptions     Redemption[]
  // Evento vinculado (para recompensas que são postadas quando evento finaliza)
  linkedEventId   String?      @unique
  linkedEvent     Event?       @relation("EventReward", fields: [linkedEventId], references: [id], onDelete: SetNull)
  isEventReward   Boolean      @default(false) // Marcado quando é recompensa de evento
  publishedAt     DateTime?    // Quando a recompensa foi publicada automaticamente
}

model Redemption {
  id          String    @id @default(uuid())
  userId      String
  rewardId    String
  cost        Int
  redeemedAt  DateTime  @default(now())
  completedAt DateTime?
  metadata    Json?
  status      String    @default("PENDING")
  reward      Reward    @relation(fields: [rewardId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
}

model PointHistory {
  id        String   @id @default(uuid())
  userId    String
  amount    Int
  reason    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model ZionHistory {
  id        String       @id @default(uuid())
  userId    String
  amount    Int
  reason    String
  currency  ZionCurrency @default(POINTS) // POINTS ou CASH
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([currency])
  @@index([createdAt])
}

enum ZionCurrency {
  POINTS // Zions Points - moeda para customizações
  CASH   // Zions Cash - moeda real (1 cash = R$ 1,00)
}

model Friendship {
  id          String           @id @default(uuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  addressee   User             @relation("FriendRequestsReceived", fields: [addresseeId], references: [id])
  requester   User             @relation("FriendRequestsSent", fields: [requesterId], references: [id])

  @@unique([requesterId, addresseeId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  content   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@index([userId, read])
}

model PostTag {
  id     String @id @default(uuid())
  postId String
  tag    String
  post   Post   @relation(fields: [postId], references: [id])
}

model InviteRequest {
  id        String        @id @default(uuid())
  name      String
  email     String        @unique
  instagram String?
  status    RequestStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

// Solicitação de Post Patrocinado
model SponsoredPostRequest {
  id            String        @id @default(uuid())
  postId        String
  userId        String
  zionsCashPaid Float         @default(0)
  status        RequestStatus @default(PENDING)
  reviewedBy    String?
  reviewedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  post          Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  user          User          @relation("SponsoredPostRequests", fields: [userId], references: [id], onDelete: Cascade)
  reviewer      User?         @relation("SponsoredPostReviewer", fields: [reviewedBy], references: [id])

  @@index([postId])
  @@index([userId])
  @@index([status])
}

model Announcement {
  id                 String   @id @default(uuid())
  title              String
  logoUrl            String
  tag                String
  subscriptionType   String
  description        String
  backgroundImageUrl String?
  buttonText         String   @default("Conhecer Agora")
  link               String   @default("/srt-log")
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model PageContent {
  id        String   @id @default(uuid())
  key       String   @unique
  content   Json
  updatedAt DateTime @updatedAt
}

model SystemLog {
  id        String   @id @default(uuid())
  level     String
  source    String
  message   String
  timestamp DateTime @default(now())
  metadata  Json?
}

model CatalogPhoto {
  id          String   @id @default(uuid())
  userId      String
  imageUrl    String
  title       String?
  description String?
  category    String?
  carValue    String?
  eventType   String?
  carBrand    String?
  isPublic    Boolean  @default(true)
  isFavorite  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}

model ZionPurchase {
  id              String   @id @default(uuid())
  userId          String
  amount          Int      // Quantidade de Zions
  price           Float    // Preço em reais
  paymentId       String?  @unique // ID do pagamento no Mercado Pago
  preferenceId    String?  @unique // ID da preferência no Mercado Pago
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED, CANCELLED, REFUNDED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([paymentId])
  @@index([preferenceId])
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime
  imageUrl    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  category    String?
  game        String?
  tag         String?   // Tag para posts relacionados ao evento (ex: "EncontroBR")
  // Recompensa vinculada (publicada quando evento finaliza)
  linkedReward Reward? @relation("EventReward")
  // Drop exclusivo de evento (item do "Meu Estilo")
  dropItemId     String?       // ID do item (ex: "bg_aurora", "badge_diamond")
  dropItemType   String?       // "background" | "badge" | "color" | "profileBorder"
  dropKeyword    String?       // Palavra-chave secreta (revelada no evento)
  dropClaimUntil DateTime?     // Até quando pode resgatar
  dropClaims     EventDropClaim[]
  attendees      EventAttendee[]
  tournament     Tournament?
}

// Registro de quem confirmou presença no evento
model EventAttendee {
  id        String   @id @default(uuid())
  eventId   String
  userId    String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId]) // Cada usuário só confirma uma vez por evento
  @@index([eventId])
  @@index([userId])
}

// Registro de quem resgatou o drop exclusivo do evento
model EventDropClaim {
  id        String   @id @default(uuid())
  eventId   String
  userId    String
  claimedAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId]) // Cada usuário só resgata uma vez por evento
  @@index([eventId])
  @@index([userId])
}

// ============================================
// TOURNAMENT SYSTEM
// ============================================

model Tournament {
  id           String           @id @default(uuid())
  eventId      String?          @unique
  title        String
  description  String?
  game         String?
  imageUrl     String?
  format       TournamentFormat @default(SINGLE_ELIMINATION)
  teamSize     Int              @default(1) // 1=solo, 2=duo, 5=equipe
  maxTeams     Int              @default(16)
  prizePool    Int              @default(0) // Zions Cash total
  rules        String?          @db.Text
  status       TournamentStatus @default(REGISTRATION)
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  createdBy    String
  event        Event?           @relation(fields: [eventId], references: [id], onDelete: SetNull)
  teams        TournamentTeam[]
  matches      TournamentMatch[]

  @@index([status])
  @@index([createdBy])
  @@index([startDate])
}

model TournamentTeam {
  id           String              @id @default(uuid())
  tournamentId String
  name         String
  captainId    String
  seed         Int?                // Posição no seed (para brackets)
  createdAt    DateTime            @default(now())
  tournament   Tournament          @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  members      TournamentTeamMember[]
  matchesAsTeam1 TournamentMatch[] @relation("MatchTeam1")
  matchesAsTeam2 TournamentMatch[] @relation("MatchTeam2")
  matchesWon     TournamentMatch[] @relation("MatchWinner")

  @@unique([tournamentId, name])
  @@unique([tournamentId, captainId])
  @@index([tournamentId])
  @@index([captainId])
}

model TournamentTeamMember {
  id        String         @id @default(uuid())
  teamId    String
  userId    String
  joinedAt  DateTime       @default(now())
  team      TournamentTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

model TournamentMatch {
  id           String       @id @default(uuid())
  tournamentId String
  round        Int          // Rodada (1, 2, 3 = quarter, semi, final)
  position     Int          // Posição dentro da rodada
  team1Id      String?
  team2Id      String?
  score1       Int?
  score2       Int?
  winnerId     String?
  status       MatchStatus  @default(PENDING)
  scheduledAt  DateTime?
  completedAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  tournament   Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team1        TournamentTeam?  @relation("MatchTeam1", fields: [team1Id], references: [id], onDelete: SetNull)
  team2        TournamentTeam?  @relation("MatchTeam2", fields: [team2Id], references: [id], onDelete: SetNull)
  winner       TournamentTeam?  @relation("MatchWinner", fields: [winnerId], references: [id], onDelete: SetNull)

  @@unique([tournamentId, round, position])
  @@index([tournamentId])
  @@index([status])
  @@index([round])
}

// ============================================
// MODERATION SYSTEM
// ============================================

model ModerationLog {
  id        String           @id @default(uuid())
  userId    String
  postId    String?
  commentId String?
  type      ModerationType
  reason    String
  action    ModerationAction
  score     Float            @default(0) // Confidence score (0-1)
  details   Json?            // Extra metadata (categories, raw API response)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([postId])
  @@index([type])
  @@index([action])
  @@index([createdAt])
}

// ============================================
// APP SETTINGS (Key-Value store for configs)
// ============================================

model AppSettings {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model Report {
  id         String       @id @default(uuid())
  reporterId String
  postId     String?
  userId     String?
  reason     String
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  resolvedAt DateTime?
  resolvedBy String?
  reporter   User         @relation("ReportsSent", fields: [reporterId], references: [id])
}

model Group {
  id             String         @id @default(uuid())
  name           String
  description    String?
  avatarUrl      String?
  creatorId      String
  membershipType MembershipType
  isPrivate      Boolean        @default(false)
  maxMembers     Int            @default(100)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  backgroundId   String?
  nsfw           Boolean        @default(false)
  creator        User           @relation("GroupCreator", fields: [creatorId], references: [id])
  invites        GroupInvite[]
  members        GroupMember[]
  messages       GroupMessage[]
  settings       GroupSettings?
  voiceChannels  VoiceChannel[]

  @@index([creatorId])
  @@index([membershipType])
  @@index([isPrivate])
  @@index([createdAt])
}

model GroupMember {
  id          String    @id @default(uuid())
  groupId     String
  userId      String
  role        GroupRole @default(MEMBER)
  joinedAt    DateTime  @default(now())
  canPost     Boolean   @default(true)
  canInvite   Boolean   @default(false)
  canModerate Boolean   @default(false)
  isMuted     Boolean   @default(false)
  nickname    String?
  group       Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user        User      @relation("UserGroupMemberships", fields: [userId], references: [id])

  @@unique([groupId, userId])
  @@index([userId])
  @@index([role])
}

model GroupMessage {
  id        String      @id @default(uuid())
  groupId   String
  senderId  String
  content   String
  imageUrl  String?
  type      MessageType @default(TEXT)
  createdAt DateTime    @default(now())
  editedAt  DateTime?
  deletedAt DateTime?
  isNSFW    Boolean     @default(false)
  replyToId String?
  group     Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender    User        @relation("UserGroupMessages", fields: [senderId], references: [id])
  readBy    GroupMessageRead[]
  reactions GroupMessageReaction[]
  replyTo   GroupMessage?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   GroupMessage[] @relation("MessageReplies")

  @@index([groupId])
  @@index([senderId])
  @@index([createdAt])
  @@index([replyToId])
}

model GroupMessageReaction {
  id        String       @id @default(uuid())
  messageId String
  userId    String
  emoji     String       // e.g., "👍", "❤️", "😂"
  createdAt DateTime     @default(now())
  message   GroupMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User         @relation("UserGroupMessageReactions", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@index([userId])
}

// Track which users have read which messages
model GroupMessageRead {
  id        String       @id @default(uuid())
  messageId String
  userId    String
  readAt    DateTime     @default(now())
  message   GroupMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

