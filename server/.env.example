PORT=3000
JWT_SECRET=change_this_to_a_secure_secret
# Default SQLite for local development
DATABASE_URL="file:./dev.db"
# For Vercel/Production (PostgreSQL required):
# DATABASE_URL="postgresql://user:password@host:port/database?schema=public"

# Frontend URL for redirects
FRONTEND_URL=https://magazine-frontend.vercel.app

# Discord OAuth
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=https://magazine-srt.vercel.app/api/social/discord/callback

# Steam OAuth
STEAM_API_KEY=your_steam_api_key
STEAM_REALM=https://magazine-srt.vercel.app

# Twitch API
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret
TWITCH_ACCESS_TOKEN=your_twitch_app_access_token

# Rovex Platform Integration
# Este secret será fornecido pelo admin da Rovex ao cadastrar a comunidade
ROVEX_API_URL=https://rovex-platform-production.up.railway.app
ROVEX_API_SECRET=your_rovex_api_secret_here

# Vercel Cron Security
# Gere um secret aleatório: openssl rand -hex 32
CRON_SECRET=your_cron_secret_here

# Community Plan (FREE, STARTER, GROWTH, ENTERPRISE)
COMMUNITY_PLAN=ENTERPRISE

# Mercado Pago - Pagamentos PIX
# Para testes: Use o Access Token de TESTE
# Obtenha em: https://www.mercadopago.com.br/developers/panel/app/{app_id}/test-credentials
MERCADOPAGO_ACCESS_TOKEN=APP_USR-0000000000000000-000000-00000000000000000000000000000000-000000000

# Modo de teste - usar 'true' para testes com credenciais de teste
MERCADOPAGO_TEST_MODE=true

# Email do usuário de teste do Mercado Pago (criar em: https://www.mercadopago.com.br/developers/panel/test-users)
MERCADOPAGO_TEST_USER_EMAIL=test_user_123456@testuser.com

# MODO SIMULAÇÃO - Não chama API do MercadoPago, gera PIX fake para testar fluxo
# Use 'true' se não conseguir configurar credenciais de teste corretamente
MERCADOPAGO_SIMULATION_MODE=true

# App Version
APP_VERSION=0.4.24

# Google Perspective API (Content Moderation)
# Obtenha em: https://console.cloud.google.com/apis/api/commentanalyzer.googleapis.com
PERSPECTIVE_API_KEY=your_perspective_api_key_here
