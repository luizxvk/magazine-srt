{
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://magazine-srt.vercel.app/api/:path*"
        },
        {
            "source": "/post/:id",
            "destination": "https://magazine-srt.vercel.app/api/og/post/:id",
            "has": [
                {
                    "type": "header",
                    "key": "user-agent",
                    "value": ".*(WhatsApp|Telegram|facebookexternalhit|Twitterbot|LinkedInBot|Slackbot|Discordbot|bot|crawl|spider).*"
                }
            ]
        },
        {
            "source": "/:path((?!ads\\.txt|sw\\.js|assets|packs|sounds|manifest\\.json|favicon\\.ico).*)",
            "destination": "/index.html"
        }
    ]
}