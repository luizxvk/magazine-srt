// ========== MARKET SYSTEM ==========

model MarketListing {
  id           String              @id @default(uuid())
  sellerId     String
  itemId       String              // The customization item ID (bg_aurora, badge_skull, etc.)
  itemType     String              // 'background' | 'badge' | 'color'
  price        Int                 // Price in Zions
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  status       MarketListingStatus @default(ACTIVE)
  // Market 6.0 - Features
  isFeatured   Boolean             @default(false) // Anúncio em destaque (pago)
  featuredUntil DateTime?          // Até quando está em destaque
  eliteOnly    Boolean             @default(false) // Apenas Elite pode comprar
  itemName     String?             // Nome do item para busca/display
  seller       User                @relation("MarketSeller", fields: [sellerId], references: [id])
  transactions MarketTransaction[]
  favorites    MarketFavorite[]    // Quem favoritou
  offers       MarketOffer[]       // Ofertas recebidas

  @@index([sellerId])
  @@index([itemType])
  @@index([status])
  @@index([price])
  @@index([createdAt])
  @@index([isFeatured])
  @@index([eliteOnly])
}

model MarketTransaction {
  id          String        @id @default(uuid())
  listingId   String
  buyerId     String
  sellerId    String
  itemId      String
  itemType    String
  price       Int
  createdAt   DateTime      @default(now())
  listing     MarketListing @relation(fields: [listingId], references: [id])
  buyer       User          @relation("MarketBuyer", fields: [buyerId], references: [id])
  seller      User          @relation("MarketTransactionSeller", fields: [sellerId], references: [id])

  @@index([buyerId])
  @@index([sellerId])
  @@index([createdAt])
}

enum MarketListingStatus {
  ACTIVE
  SOLD
  CANCELLED
}

// Favoritos/Watchlist do Mercado
model MarketFavorite {
  id        String        @id @default(uuid())
  userId    String
  listingId String
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   MarketListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
}

// Ofertas/Propostas no Mercado
model MarketOffer {
  id         String            @id @default(uuid())
  listingId  String
  buyerId    String
  sellerId   String
  amount     Int               // Valor oferecido em Zions
  message    String?           // Mensagem opcional do comprador
  status     MarketOfferStatus @default(PENDING)
  createdAt  DateTime          @default(now())
  respondedAt DateTime?        // Quando vendedor respondeu
  listing    MarketListing     @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer      User              @relation("OfferBuyer", fields: [buyerId], references: [id])
  seller     User              @relation("OfferSeller", fields: [sellerId], references: [id])

  @@index([listingId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([createdAt])
}

enum MarketOfferStatus {
  PENDING    // Aguardando resposta
  ACCEPTED   // Aceita (venda realizada)
  REJECTED   // Recusada pelo vendedor
  EXPIRED    // Expirou (24h)
  CANCELLED  // Cancelada pelo comprador
}

// ========== PRODUCT STORE SYSTEM ==========

model Product {
  id            String          @id @default(uuid())
  name          String
  description   String          @db.Text
  imageUrl      String?
  screenshots   String[]        // Array of additional screenshot URLs
  category      ProductCategory
  priceZions    Int?            // Price in Zions (optional)
  priceBRL      Float?          // Price in BRL (optional)
  stock         Int             @default(0)
  isUnlimited   Boolean         @default(false)
  isActive      Boolean         @default(true)
  magazineDiscount Boolean      @default(false) // 10% discount for MAGAZINE members
  // Payment Options
  acceptedPaymentMethods String[] @default([])  // ZIONS, PIX, MERCADO_PAGO
  pixKey        String?         // Seller's PIX key for direct PIX payments
  pixKeyType    PixKeyType?     // Type of PIX key (CPF, CNPJ, EMAIL, PHONE, RANDOM)
  pixApprovalStatus PixApprovalStatus @default(NONE) // Rovex PIX approval status
  pixSellerRequests PixSellerRequest[]
  // Game/Product Info
  developer     String?         // Developer/Publisher
  releaseDate   String?         // Release date
  sizeGB        Float?          // Size in GB
  platform      String?         // Platform (PC, Xbox, PS, etc)
  tags          ProductTag[]    // Tags relationship
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  createdById   String
  createdBy     User            @relation("ProductCreator", fields: [createdById], references: [id])
  keys          ProductKey[]
  orders        Order[]
  linkedPosts   Post[]          @relation("PostProduct")
  
  @@index([category])
  @@index([isActive])
  @@index([priceZions])
  @@index([priceBRL])
}

model ProductTag {
  id        String   @id @default(uuid())
  productId String
  tag       String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@unique([productId, tag])
  @@index([tag])
}

model ProductKey {
  id          String    @id @default(uuid())
  productId   String
  key         String    // The actual game key/code (encrypted in production)
  isUsed      Boolean   @default(false)
  usedAt      DateTime?
  usedById    String?
  orderId     String?
  createdAt   DateTime  @default(now())
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  order       Order?    @relation(fields: [orderId], references: [id])
  
  @@index([productId])
  @@index([isUsed])
}

model Order {
  id            String        @id @default(uuid())
  buyerId       String
  buyer         User          @relation(fields: [buyerId], references: [id])
  productId     String
  quantity      Int           @default(1)
  totalZions    Int?          // Total paid in Zions
  totalBRL      Float?        // Total paid in BRL
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(PENDING)
  paymentId     String?       // External payment ID (Stripe/MercadoPago)
  deliveredKeys ProductKey[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  product       Product       @relation(fields: [productId], references: [id])
  
  @@index([buyerId])
  @@index([productId])
  @@index([paymentStatus])
  @@index([createdAt])
}

