generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  name         String
  displayName  String?
  avatarUrl    String?
  bio          String?
  role         Role          @default(MEMBER)
  points       Int           @default(0)
  trophies     Int           @default(0)
  level        Int           @default(1)
  xp           Int           @default(0)
  zions        Int           @default(0)
  membershipType MembershipType @default(MAGAZINE)
  isOnline     Boolean       @default(false)
  lastSeenAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  resetToken   String?
  resetTokenExpiry DateTime?
  deletedAt    DateTime?
  sessionToken String?       // For single device login - invalidates previous sessions
  
  // Email Verification
  isVerified          Boolean   @default(false)
  verificationCode    String?
  verificationExpiry  DateTime?
  verificationSentAt  DateTime?
  
  // Customization shop fields
  ownedCustomizations String?   // JSON array of owned item IDs
  equippedBackground  String?   // Currently equipped background ID
  equippedBadge       String?   // Currently equipped badge ID
  equippedColor       String?   // Currently equipped neon color ID
  liteMode            Boolean   @default(false) // Disable animations/effects
  
  posts        Post[]
  comments     Comment[]
  likes        Like[]
  badges       UserBadge[]
  pointHistory PointHistory[]
  zionHistory  ZionHistory[]
  redemptions  Redemption[]
  notifications Notification[]
  
  sentMessages   Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  
  friendRequestsSent     Friendship[] @relation("FriendRequestsSent")
  friendRequestsReceived Friendship[] @relation("FriendRequestsReceived")

  stories      Story[]
  storyViews   StoryView[]
  catalogPhotos CatalogPhoto[]
  zionPurchases ZionPurchase[]
  reportsSent  Report[] @relation("ReportsSent")

  // Grupos
  groupsCreated    Group[] @relation("GroupCreator")
  groupMemberships GroupMember[] @relation("UserGroupMemberships")
  groupMessages    GroupMessage[] @relation("UserGroupMessages")
  
  // Admin Badges
  adminBadges AdminBadge[]

  // Performance indexes
  @@index([membershipType])
  @@index([isOnline])
  @@index([createdAt])
  @@index([trophies])
  @@index([zions])
}

model Story {
  id        String   @id @default(uuid())
  userId    String
  imageUrl  String
  createdAt DateTime @default(now())
  expiresAt DateTime

  user      User     @relation(fields: [userId], references: [id])
  views     StoryView[]

  @@index([userId])
  @@index([expiresAt])
  @@index([createdAt])
}

model StoryView {
  id        String   @id @default(uuid())
  storyId   String
  viewerId  String
  viewedAt  DateTime @default(now())

  story     Story    @relation(fields: [storyId], references: [id])
  viewer    User     @relation(fields: [viewerId], references: [id])

  @@unique([storyId, viewerId])
}

model Message {
  id            String   @id @default(uuid())
  senderId      String
  receiverId    String
  content       String
  storyImageUrl String?
  read          Boolean  @default(false)
  createdAt     DateTime @default(now())

  sender    User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver  User     @relation("ReceivedMessages", fields: [receiverId], references: [id])

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
  @@index([senderId, receiverId])
}

model Post {
  id          String    @id @default(uuid())
  userId      String
  imageUrl    String?
  videoUrl    String?
  caption     String?
  likesCount  Int       @default(0)
  commentsCount Int     @default(0)
  reportsCount Int      @default(0)
  isHighlight Boolean   @default(false)
  isPublic    Boolean   @default(true)
  isRemoved   Boolean   @default(false)
  mediaType   MediaType @default(IMAGE)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id])
  comments    Comment[]
  likes       Like[]
  tags        PostTag[]

  @@index([userId])
  @@index([createdAt])
  @@index([isHighlight])
  @@index([isRemoved])
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  text      String
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([postId])
  @@index([userId])
  @@index([createdAt])
}

model Like {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
}

model Badge {
  id          String      @id @default(uuid())
  name        String
  description String
  iconUrl     String
  trophies    Int         @default(0)
  users       UserBadge[]
}

model UserBadge {
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  badge     Badge    @relation(fields: [badgeId], references: [id])

  @@id([userId, badgeId])
}

model Reward {
  id          String       @id @default(uuid())
  title       String
  type        RewardType
  costZions   Int          @default(0)
  stock       Int
  metadata    Json?
  backgroundColor String?
  redemptions Redemption[]
}

model Redemption {
  id         String   @id @default(uuid())
  userId     String
  rewardId   String
  cost       Int
  redeemedAt DateTime @default(now())
  status     String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, CANCELLED
  completedAt DateTime?
  metadata   Json?

  user       User     @relation(fields: [userId], references: [id])
  reward     Reward   @relation(fields: [rewardId], references: [id])
}

model PointHistory {
  id        String   @id @default(uuid())
  userId    String
  amount    Int
  reason    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model ZionHistory {
  id        String   @id @default(uuid())
  userId    String
  amount    Int
  reason    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model Friendship {
  id          String           @id @default(uuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester   User @relation("FriendRequestsSent", fields: [requesterId], references: [id])
  addressee   User @relation("FriendRequestsReceived", fields: [addresseeId], references: [id])

  @@unique([requesterId, addresseeId])
}

enum Role {
  MEMBER
  ADMIN
  VISITOR
}

enum MembershipType {
  MAGAZINE
  MGT
}

enum RewardType {
  PRODUCT
  COUPON
  DIGITAL
}

enum NotificationType {
  LIKE
  COMMENT
  SYSTEM
  BADGE
  FRIEND_REQUEST
  MESSAGE
}

enum MediaType {
  IMAGE
  VIDEO
  TEXT
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  content   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@index([userId, read])
}

model PostTag {
  id     String @id @default(uuid())
  postId String
  tag    String

  post Post @relation(fields: [postId], references: [id])
}

model InviteRequest {
  id        String        @id @default(uuid())
  name      String
  email     String        @unique
  instagram String?
  status    RequestStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Announcement {
  id               String   @id @default(uuid())
  title            String
  logoUrl          String
  tag              String
  subscriptionType String
  description      String
  backgroundImageUrl String?
  buttonText       String   @default("Conhecer Agora")
  link             String   @default("/srt-log")
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model PageContent {
  id        String   @id @default(uuid())
  key       String   @unique
  content   Json
  updatedAt DateTime @updatedAt
}

model SystemLog {
  id        String   @id @default(uuid())
  level     String   // INFO, WARN, ERROR
  source    String   // FRONTEND, BACKEND
  message   String
  timestamp DateTime @default(now())
  metadata  Json?
}

model CatalogPhoto {
  id          String   @id @default(uuid())
  userId      String
  imageUrl    String
  title       String?
  description String?
  category    String?  // Sport, SUV, Sedan, Muscle, JDM, Euro, Classic
  carValue    String?  // Budget, Mid, Premium, Supercar
  eventType   String?  // Drift, Street, Meeting, Roleplay, Race
  carBrand    String?  // BMW, Toyota, Nissan, Ford, Chevrolet...
  isPublic    Boolean  @default(true)
  isFavorite  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model ZionPurchase {
  id            String   @id @default(uuid())
  userId        String
  amount        Int
  price         Float
  paymentId     String?
  preferenceId  String?
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED, CANCELLED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime
  category    String?
  game        String?
  imageUrl    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Report {
  id          String       @id @default(uuid())
  reporterId  String
  postId      String?
  userId      String?      // Reported user
  reason      String
  status      ReportStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  resolvedAt  DateTime?
  resolvedBy  String?

  reporter    User         @relation("ReportsSent", fields: [reporterId], references: [id])
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

// ===== SISTEMA DE GRUPOS =====

model Group {
  id              String         @id @default(uuid())
  name            String
  description     String?
  avatarUrl       String?
  creatorId       String
  membershipType  MembershipType // MAGAZINE ou MGT
  isPrivate       Boolean        @default(false)
  maxMembers      Int            @default(100)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  creator         User           @relation("GroupCreator", fields: [creatorId], references: [id])
  members         GroupMember[]
  messages        GroupMessage[]
  settings        GroupSettings?

  @@index([creatorId])
  @@index([membershipType])
  @@index([isPrivate])
  @@index([createdAt])
}

model GroupMember {
  id          String    @id @default(uuid())
  groupId     String
  userId      String
  role        GroupRole @default(MEMBER)
  joinedAt    DateTime  @default(now())
  canPost     Boolean   @default(true)
  canInvite   Boolean   @default(false)
  canModerate Boolean   @default(false)

  group       Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user        User      @relation("UserGroupMemberships", fields: [userId], references: [id])

  @@unique([groupId, userId])
  @@index([userId])
  @@index([role])
}

enum GroupRole {
  ADMIN
  MODERATOR
  MEMBER
}

model GroupMessage {
  id        String      @id @default(uuid())
  groupId   String
  senderId  String
  content   String
  imageUrl  String?
  type      MessageType @default(TEXT)
  createdAt DateTime    @default(now())
  editedAt  DateTime?
  deletedAt DateTime?

  group     Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender    User        @relation("UserGroupMessages", fields: [senderId], references: [id])

  @@index([groupId])
  @@index([senderId])
  @@index([createdAt])
}

enum MessageType {
  TEXT
  IMAGE
  ANNOUNCEMENT
}

model GroupSettings {
  id                    String  @id @default(uuid())
  groupId               String  @unique
  requireApproval       Boolean @default(false)
  allowMemberPosts      Boolean @default(true)
  allowExternalInvites  Boolean @default(false)
  muteNotifications     Boolean @default(false)

  group                 Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model AdminBadge {
  id        String   @id @default(uuid())
  text      String   // e.g., "BETA", "DEV", "MGT"
  color     String   // Background color hex (e.g., "#FF0000")
  userId    String   // User who has this badge
  createdAt DateTime @default(now())
  createdBy String   // Admin who created it
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdBy])
}
