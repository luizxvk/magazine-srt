// ============================================
// STATFORGE - GAME STATS TRACKER
// ============================================

model GameProfile {
  id            String   @id @default(uuid())
  userId        String
  game          String   // "r6siege", "cs2", "valorant", "lol", etc.
  platform      String   // "pc", "xbox", "playstation", "steam"
  gamertag      String   // Username/ID no jogo
  platformId    String?  // ID específico da plataforma (Steam64, Riot PUUID, etc.)
  avatarUrl     String?  // Avatar no jogo
  isVerified    Boolean  @default(false) // Se confirmou que é dono da conta
  isActive      Boolean  @default(true)
  lastSyncedAt  DateTime?
  metadata      Json?    // Dados extras do perfil (rank icon, etc.)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshots     GameSnapshot[]

  @@unique([userId, game, platform])
  @@index([userId])
  @@index([game])
  @@index([platform])
  @@index([gamertag])
}

model GameSnapshot {
  id            String   @id @default(uuid())
  profileId     String
  rank          String?  // "Diamond 3", "Global Elite", etc.
  rankTier      Int?     // Numeric rank for comparison (1=lowest)
  level         Int?     // In-game level
  kd            Float?   // Kill/Death ratio
  winRate       Float?   // Win percentage (0-100)
  totalMatches  Int?
  totalWins     Int?
  totalKills    Int?
  totalDeaths   Int?
  hoursPlayed   Float?
  score         Int?     // Generic score/MMR/ELO
  stats         Json?    // Game-specific detailed stats
  createdAt     DateTime @default(now())
  profile       GameProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([createdAt])
  @@index([rank])
}

model GameEvent {
  id            String   @id @default(uuid())
  profileId     String?  // Null for global events (price drops etc.)
  userId        String?  // User associated (for feed)
  game          String
  eventType     String   // "rank_up", "rank_down", "achievement", "milestone", "price_drop", "new_game"
  title         String
  description   String?
  oldValue      String?  // Previous rank/value
  newValue      String?  // New rank/value
  iconUrl       String?
  metadata      Json?    // Extra data
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([game])
  @@index([eventType])
  @@index([createdAt])
  @@index([isRead])
}

// ============================================
// COUPON SYSTEM
// ============================================

model Coupon {
  id                String       @id @default(uuid())
  code              String       @unique
  description       String?
  discountType      DiscountType @default(FIXED)
  discountValue     Float        // R$ value (FIXED) or percentage (PERCENTAGE)
  minPurchase       Float?       // Minimum purchase value in BRL
  maxDiscount       Float?       // Max discount cap for PERCENTAGE type
  maxUses           Int?         // Total max uses (null = unlimited)
  maxUsesPerUser    Int          @default(1) // Per user limit
  usedCount         Int          @default(0)
  isActive          Boolean      @default(true)
  isEliteOnly       Boolean      @default(false) // Only for Elite members
  isAutoGenerated   Boolean      @default(false) // Auto-generated for Elite monthly
  expiresAt         DateTime?
  // Rovex Approval
  rovexApproval     CouponApprovalStatus @default(PENDING)
  rovexReviewedAt   DateTime?
  rovexReviewNote   String?      @db.Text
  createdById       String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  usages            CouponUsage[]

  @@index([code])
  @@index([isActive])
  @@index([isEliteOnly])
  @@index([rovexApproval])
  @@index([expiresAt])
  @@index([createdById])
}

model CouponUsage {
  id        String   @id @default(uuid())
  couponId  String
  userId    String
  orderId   String?  // Order where it was applied
  discount  Float    // Actual discount applied in BRL
  createdAt DateTime @default(now())
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@unique([couponId, userId, orderId])
  @@index([couponId])
  @@index([userId])
  @@index([createdAt])
}

enum DiscountType {
  FIXED       // R$ fixo de desconto
  PERCENTAGE  // Percentual de desconto
}

enum CouponApprovalStatus {
  PENDING    // Aguardando aprovação da Rovex
  APPROVED   // Aprovado
  REJECTED   // Rejeitado
}

// ============================================
// CHALLENGE SYSTEM - 1v1 DUELS
// ============================================

model Challenge {
  id                String          @id @default(uuid())
  challengerId      String          // Quem criou o desafio
  opponentId        String          // Quem foi desafiado
  gameProfileId     String          // Perfil do challenger (para saber o jogo)
  opponentProfileId String?         // Perfil do oponente (preenchido ao aceitar)
  game              String          // Nome do jogo ("valorant", "cs2", etc.)
  metric            ChallengeMetric // Métrica do desafio (kills, wins, kd)
  targetValue       Int?            // (Opcional) Valor alvo a atingir
  betAmount         Int             // Quantidade de Zions apostada (cada lado)
  duration          Int             @default(3) // Prazo em dias
  status            ChallengeStatus @default(PENDING)
  winnerId          String?         // ID do vencedor
  
  // Snapshots - Stats no início e fim do desafio
  challengerStartStats  Json?       // Snapshot inicial do challenger
  opponentStartStats    Json?       // Snapshot inicial do opponent
  challengerEndStats    Json?       // Snapshot final do challenger
  opponentEndStats      Json?       // Snapshot final do opponent
  
  // Resultados calculados
  challengerDelta   Float?          // Diferença de performance do challenger
  opponentDelta     Float?          // Diferença de performance do opponent
  
  expiresAt         DateTime?       // Quando o desafio expira (para aceitar)
  startsAt          DateTime?       // Quando o desafio começou
  endsAt            DateTime?       // Quando termina (startsAt + duration)
  completedAt       DateTime?       // Quando foi finalizado
  
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  
  // Relations
  challenger        User            @relation("ChallengeSent", fields: [challengerId], references: [id])
  opponent          User            @relation("ChallengeReceived", fields: [opponentId], references: [id])
  
  @@index([challengerId])
  @@index([opponentId])
  @@index([game])
  @@index([status])
  @@index([createdAt])
}

enum ChallengeStatus {
  PENDING      // Aguardando aceite do oponente
  ACCEPTED     // Aceito, aguardando início
  IN_PROGRESS  // Em andamento
  COMPLETED    // Finalizado
  CANCELLED    // Cancelado pelo challenger
  DECLINED     // Recusado pelo opponent
  EXPIRED      // Expirou sem resposta
}

enum ChallengeMetric {
  KILLS        // Total de eliminações
  WINS         // Total de vitórias
  KD           // Melhor K/D ratio
  WIN_RATE     // Melhor % de vitória
  SCORE        // Maior score/ELO ganho
  HOURS        // Mais horas jogadas
}

// ============================================
// ROVEX CONNECT - Voice & Streaming
// ============================================

model VoiceChannel {
  id           String    @id @default(uuid())
  groupId      String
  name         String
  description  String?
  maxUsers     Int       @default(25)
  isLocked     Boolean   @default(false)
  bitrate      Int       @default(64000) // Audio quality in bps
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  group        Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  participants VoiceParticipant[]
  
  @@index([groupId])
}

model VoiceParticipant {
  id             String       @id @default(uuid())
  channelId      String
  userId         String
  isMuted        Boolean      @default(false)
  isDeafened     Boolean      @default(false)
  isSpeaking     Boolean      @default(false)
  isStreaming    Boolean      @default(false)
  joinedAt       DateTime     @default(now())
  
  channel        VoiceChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([channelId, userId])
  @@index([userId])
  @@index([channelId])
}

// ============================================
// SYSTEM CONFIGURATION
// ============================================

model SystemConfig {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}
