{
    "version": 2,
    "builds": [
        {
            "src": "index.ts",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "index.ts"
        }
    ],
    "headers": [
        {
            "source": "/api/social/(.*)",
            "headers": [
                {
                    "key": "Content-Security-Policy",
                    "value": "default-src 'self' https://vercel.live; script-src 'self' 'unsafe-inline' https://vercel.live https://*.vercel.live;"
                }
            ]
        }
    ]
}